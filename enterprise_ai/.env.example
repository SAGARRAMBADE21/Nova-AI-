# ── OpenAI ────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4

# ── Lakera Guard ──────────────────────────────────
LAKERA_API_KEY=your_lakera_api_key
LAKERA_PROJECT_ID=your_lakera_project_id

# ── Vector DB (ChromaDB) ──────────────────────────
CHROMA_PERSIST_DIR=./data/chroma


# ── Google Suite ──────────────────────────────────
GOOGLE_CREDENTIALS_FILE=./credentials/google_credentials.json
GOOGLE_TOKEN_FILE=./credentials/google_token.json

# ── Slack ─────────────────────────────────────────
SLACK_BOT_TOKEN=your_slack_bot_token

# ── Notion ────────────────────────────────────────
NOTION_API_KEY=your_notion_api_key

# ── Grafana ───────────────────────────────────────
GRAFANA_URL=http://localhost:3000
GRAFANA_API_KEY=your_grafana_api_key

# ── LLMOps ───────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=./logs/system.log
METRICS_PORT=8001

# ── HITL ─────────────────────────────────────────
HITL_CONFIDENCE_THRESHOLD=0.4
HITL_SLA_MINUTES=30
ADMIN_EMAIL=admin@company.com
