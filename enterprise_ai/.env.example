# ── OpenAI ────────────────────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── MongoDB Atlas ──────────────────────────────────────────────────────────
# Get this from Atlas → Connect → Drivers → Python
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=nova_ai

# ── Clerk Auth ────────────────────────────────────────────────────────────
# Clerk Dashboard → API Keys
CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
# Clerk Dashboard → API Keys → Advanced → JWKS URL
# Format: https://<your-domain>.clerk.accounts.dev/.well-known/jwks.json
CLERK_JWKS_URL=

# ── Dev Mode (when CLERK_JWKS_URL is not set) ─────────────────────────────
# Used for local dev only — all requests treated as this tenant with admin role
DEV_TENANT_ID=dev_tenant

# ── Lakera Guard ──────────────────────────────────────────────────────────
LAKERA_API_KEY=your_lakera_api_key
LAKERA_PROJECT_ID=your_lakera_project_id

# ── Google Suite ──────────────────────────────────────────────────────────
GOOGLE_CREDENTIALS_FILE=./credentials/google_credentials.json
GOOGLE_TOKEN_FILE=./credentials/google_token.json

# ── Slack (optional — add plugin and register in plugins/registry.py to enable) ───────
# SLACK_BOT_TOKEN=your_slack_bot_token

# ── Notion (optional — add plugin and register in plugins/registry.py to enable) ──────
# NOTION_API_KEY=your_notion_api_key

# ── LLMOps ───────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=./logs/system.log

# ── HITL ─────────────────────────────────────────────────────────────────
HITL_SLA_MINUTES=30
ADMIN_EMAIL=admin@company.com
